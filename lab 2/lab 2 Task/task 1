// Program to display value, size (in bytes) and memory location of different data types

#include <iostream>   // iostream library include ki gayi hai input/output ke liye
using namespace std;  // std namespace use kiya taake cout aur endl directly use ho sake

int main()            // main function: program ka starting point
{
    int a = 10;        // Integer variable declare kiya aur value 10 assign ki
    float b = 5.5;     // Float variable declare kiya aur value 5.5 assign ki
    double c = 20.99;  // Double variable declare kiya, zyada precise decimal value ke liye
    char d = 'A';      // Char variable declare kiya aur value 'A' assign ki
    bool e = true;     // Boolean variable declare kiya aur value true assign ki

    // Integer details
    cout << "Integer value: " << a << endl;
    cout << "Size of int: " << sizeof(a) << " bytes" << endl;
    cout << "Location of int: " << &a << endl;
    cout << endl;

    // Float details
    cout << "Float value: " << b << endl;
    cout << "Size of float: " << sizeof(b) << " bytes" << endl;
    cout << "Location of float: " << &b << endl;
    cout << endl;

    // Double details
    cout << "Double value: " << c << endl;
    cout << "Size of double: " << sizeof(c) << " bytes" << endl;
    cout << "Location of double: " << &c << endl;
    cout << endl;

    // Char details
    cout << "Char value: " << d << endl;
    cout << "Size of char: " << sizeof(d) << " bytes" << endl;
    cout << "Location of char: " << (void*)&d << endl; // (void*) cast se address print hoga
    cout << endl;

    // Bool details
    cout << "Bool value: " << e << endl;  
    cout << "Size of bool: " << sizeof(e) << " bytes" << endl;
    cout << "Location of bool: " << &e << endl;

    return 0;   // Program successfully end ho gaya
}
